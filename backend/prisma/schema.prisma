generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     Role   @default(VICTIM)
}

enum Role {
  RESCUE_TEAM
  DONOR
  VICTIM
  ADMIN
}

model Disaster {
  id           Int      @id @default(autoincrement())
  disasterType String
  province     String
  district     String
  city         String
  date         String
  time         String
}

model Victim {
  id       Int    @id @default(autoincrement())
  fullName String
  email    String
  province String
  district String
  city     String
  date     String
  time     String
  isApproved Boolean @default(false)
}

model Donor {
  id       Int    @id @default(autoincrement())
  fullName String
  email    String
  province String
  district String
  city     String
  date     String
  time     String
  isApproved Boolean @default(false)
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int?     
  targetRole String?  
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}